{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:allow-save",
    "core:window:allow-set-size",
    "core:window:allow-outer-size",
    "core:window:allow-inner-size"
  ]
}
