{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LaTeX-PNG Tauri App",
  "version": "0.1.0",
  "identifier": "com.gabrielesano.latex-to-png",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "title": "LaTeX-PNG",
        "width": 720,
        "height": 960,
        "minWidth": 300,
        "minHeight": 150,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
